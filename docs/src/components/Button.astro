---
type ButtonType = 'button' | 'submit' | 'reset'

interface Props {
  type?: ButtonType
  class?: string
  'aria-label'?: string
  'aria-expanded'?: boolean
  'aria-haspopup'?: boolean
  'data-dropdown-trigger'?: string
}

const {
  type = 'button',
  class: className,
  ...attrs
} = Astro.props as Props

const classes = [
  'inline-flex items-center gap-2',
  'h-12 px-3',
  'rounded-md',
  'whitespace-nowrap',
  'bg-slate-100 text-slate-700',
  'cursor-pointer',
  'transition-colors duration-300',
  'hover:bg-slate-200',
  'focus:outline-none',
  className
]
  .filter(Boolean)
  .join(' ')
---

<button type={type} class={classes} {...attrs}>
  <slot />
</button>
