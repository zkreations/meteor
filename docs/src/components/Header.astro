---
import { Meteor, Github, X, Sun, Moon } from '@meteor-icons/astro'
import { version } from '../../../package.json';

const githubUrl = 'https://github.com/zkreations/meteor';
const twitterUrl = 'https://x.com/intent/tweet?text=Meteor%20Icons%20-%20Open%20source%20icon%20library&url=https://meteoricons.com';
---

<header class="border-b border-outline">
  <div class="flex items-center justify-between py-6 wrapper">
    <a href="/" class="flex items-center gap-3" aria-label="Meteor Icons home">
      <Meteor minimal class="w-8 h-8 text-on-surface"/>
      <span class="rounded-md bg-surface-container px-2 py-1 text-sm font-medium font-mono">{version}</span>
    </a>
    <nav class="flex items-center gap-4 text-sm">
      <a href={githubUrl} target="_blank" rel="noreferrer" class="transition hover:text-brand-active" aria-label="GitHub repository">
        <Github minimal class="w-5 h-5"/>
      </a>
      <a href={twitterUrl} target="_blank" rel="noreferrer" class="transition hover:text-brand-active" aria-label="Twitter share">
        <X minimal class="w-5 h-5"/>
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Switch to dark mode"
        data-theme="light"
        class="transition rounded-full p-2 bg-surface-container hover:bg-surface-container-high cursor-pointer"
      >
        <Moon minimal class="w-5 h-5 hidden dark:block"/>
        <Sun minimal class="w-5 h-5 block dark:hidden"/>
      </button>
    </nav>
  </div>
</header>

<script>
  import { initThemeToggle } from '@shared/ui/themeToggle'

  const button = document.getElementById('theme-toggle')
  if (button instanceof HTMLElement) {
    initThemeToggle(button)
  }
</script>
