---
const heroTitle = 'Meteor icons'
const heroDescription = 'Meteor is an open-source icon pack, handcrafted at the code level, to achieve the highest possible optimization.'
---

<section class="pt-10 md:pt-18 wrapper">
  <h1 class="text-4xl font-semibold tracking-tight text-slate-900">{heroTitle}</h1>
  <p class="mt-4 max-w-xl text-base leading-7 text-slate-600 text-balance">
    {heroDescription}
  </p>
</section>