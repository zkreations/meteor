---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js'
import IconActions from './IconActions.astro'

interface Props {
  name: string
  IconComponent: AstroComponentFactory
}

const { name, IconComponent } = Astro.props
---

<article data-open-icon-modal data-name={name} class="icon-card group" role="button" tabindex="0" aria-label={`Open modal for ${name} icon`}>
  <div class="icon-preview">
    <IconComponent size={24} />
    <p class="icon-text">{name}</p>
  </div>
  <IconActions variant="compact" />
</article>
