---
import { getCollection } from 'astro:content'
import { Search, Grid, ChevronDown, SlidersSimple, Rotate } from '@meteor-icons/astro'
import { capitalize } from '../utils/helpers'

interface Props {
  total: number,
  class?: string
}

const { total, class: className = '' } = Astro.props
const entries = await getCollection('icons')

const categoriesMap = new Map<string, { name: string; count: number }>()

entries.forEach(entry => {
  if (entry.data.categories) {
    entry.data.categories.forEach((category: string) => {
      if (!categoriesMap.has(category)) {
        categoriesMap.set(category, { name: category, count: 1 })
      } else {
        categoriesMap.get(category)!.count += 1
      }
    })
  }
})

const categories = Array.from(categoriesMap.values()).sort((a, b) => a.name.localeCompare(b.name))
---

<div
  class={`z-10 flex gap-4 items-center p-3 bg-white border border-slate-200 shadow-lg transition duration-300 focus-within:border-brand-active focus-within:ring-4 ring-brand-active/10 rounded-lg sticky top-2 ${className}`}
>

  <div class="relative select-none">
    <button class="btn w-50" data-outside="categories" aria-label="Filter by category">
      <span data-category-icon class="shrink-0">
        <Grid/>
      </span>
      <span data-category-label class="truncate">All Categories</span>
      <ChevronDown size={20} class="ml-auto shrink-0" />
    </button>

    <div class="left-0 dropdown overflow-y-auto max-h-75 scrollbar w-full" data-dropdown="categories" role="menu" aria-label="Categories">
      <div class="p-2">

        <button type="button" data-category="all" data-dropdown-close class="dropdown-item dropdown-item-active" aria-current="true">
          <span class="truncate">All categories</span>
        </button>

        {categories.map((category) => (
          <button type="button" data-category={category.name} data-dropdown-close class="dropdown-item" aria-current="false">
            <span class="truncate">{capitalize(category.name)}</span>
            <span class="ml-auto text-sm text-slate-400 font-mono">
              {category.count}
            </span>
          </button>
        ))}

      </div>
    </div>
  </div>

  <input
    data-icon-search
    type="text"
    placeholder={`Search ${total} icons`}
    class="w-full text-slate-700 outline-none bg-transparent py-3"
    aria-label="Search icons"
    autocomplete="off"
    spellcheck="false"
    name="icon-search"
  />

  <span class="pointer-events-none text-slate-400">
    <Search />
  </span>

  <div class="relative select-none bg-slate-100 rounded-lg flex h-12">
    <button class="btn" data-outside="settings" aria-label="Icon settings">
      <SlidersSimple />
    </button>

    <div class="right-0 w-72 dropdown z-50" data-dropdown="settings" role="dialog" aria-label="Icon settings">

      <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center">
        <h3 class="font-semibold text-slate-800">Settings</h3>
        <button
          data-reset-settings
          class="text-sm font-medium text-slate-600 hover:text-slate-700 cursor-pointer transition"
        >
          <Rotate size={20} />
        </button>
      </div>

      <div class="p-5 space-y-4">

        <div class="icon-setting-group">
          <label class="icon-setting-label" for="icon-color-picker">Color</label>
          <label class="flex gap-2 items-center rounded-lg bg-slate-100 p-2 cursor-pointer">
            <div class="w-12 h-8 rounded-md overflow-hidden border border-slate-200 relative">
              <input
                type="color"
                data-setting-color
                class="h-12 w-16 cursor-pointer bg-transparent absolute -ml-2 -mt-2"
                id="icon-color-picker"
              />
            </div>

            <span data-color-value class="ml-auto font-mono text-slate-500">
              currentColor
            </span>
          </label>
        </div>

        <div class="icon-setting-group">
          <div class="icon-setting-row">
            <label class="icon-setting-label" for="icon-stroke-width">Stroke width</label>
            <span data-stroke-value class="ml-auto text-sm text-slate-400 font-mono">2px</span>
          </div>
          <input
            type="range"
            data-setting-stroke
            min="1"
            max="2"
            step="0.1"
            value="2"
            class="icon-slider w-full"
            id="icon-stroke-width"
          />
        </div>

        <div class="icon-setting-group">
          <div class="icon-setting-row">
            <label class="icon-setting-label" for="icon-size">Size</label>
            <span data-size-value class="ml-auto text-sm text-slate-400 font-mono">24px</span>
          </div>
          <input
            type="range"
            data-setting-size
            min="0"
            max="340"
            step="1"
            value="8"
            class="icon-slider w-full"
            id="icon-size"
          />
          <div class="chip-list">
            <button type="button" data-size-preset="16" class="size-chip">16</button>
            <button type="button" data-size-preset="24" class="size-chip size-chip-active" aria-pressed="true">24</button>
            <button type="button" data-size-preset="32" class="size-chip">32</button>
            <button type="button" data-size-preset="48" class="size-chip">48</button>
            <button type="button" data-size-preset="64" class="size-chip">64</button>
          </div>
        </div>

      </div>
    </div>
  </div>

</div>
