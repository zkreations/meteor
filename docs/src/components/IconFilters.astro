---
import { Search, AngleDown } from '@meteor-icons/astro'

interface Props {
  total: number
}

const { total } = Astro.props
---

<div class="mb-4 flex items-center gap-4 rounded-lg border border-slate-200 bg-white p-4 shadow-md sticky top-4 z-10">
  <!-- dropdown of categories -->
  <div class="relative">
    <button class="flex items-center justify-between gap-1 rounded-md bg-slate-100 px-3 py-2 text-slate-700 w-40">
      All
      <AngleDown size={20} />
    </button>
    <!-- dropdown menu -->
    <div class="absolute left-0 top-full mt-1 hidden w-full rounded-md border border-slate-200 bg-white shadow-lg">
      <ul class="py-1 text-sm text-slate-700">
        <li><button data-category="all" class="block w-full px-4 py-2 text-left hover:bg-slate-100">All Categories</button></li>
      </ul>
    </div>
  </div>
  <input
    id="icon-search"
    type="search"
    placeholder={`Search ${total} icons`}
    class="w-full text-slate-700 outline-none bg-transparent"
    aria-label="Search icons"
    autocomplete="off"
    spellcheck="false"
  />
  <span class="pointer-events-none text-slate-400">
    <Search />
  </span>
</div>