---
import * as MeteorIcons from '@meteor-icons/astro'
import { getCollection } from 'astro:content'
import { getIconList } from '../utils/iconUtils'
import { capitalize } from '../utils/helpers'
import IconFilters from './IconFilters.astro'
import IconCard from './IconCard.astro'

const icons = getIconList(MeteorIcons)
const entries = await getCollection('icons')

const categoryMap = new Map(
  entries.map((entry) => [
    entry.data.name,
    entry.data.categories ?? []
  ])
)

const groupedIcons = new Map<string, typeof icons>()

icons.forEach((icon) => {
  const categories = categoryMap.get(icon.name) ?? ['uncategorized']

  categories.forEach((category) => {
    if (!groupedIcons.has(category)) {
      groupedIcons.set(category, []
      )
    }

    groupedIcons.get(category)?.push(icon)
  })
})

const sortedGroups = Array.from(groupedIcons.entries()).sort(([a], [b]) =>
  a.localeCompare(b)
)
---

<main class="py-10 wrapper">
  <div data-icon-grid class="flex flex-col gap-8">
    <IconFilters total={icons.length} />
    {sortedGroups.map(([category, items]) => (
      <section data-section={category}>
        <h2 class="mb-4 text-xl text-slate-800 font-semibold">
          {capitalize(category)}
          <span data-section-count class="text-base font-normal font-mono text-slate-400">
            [{items.length}]
          </span>
        </h2>

        <div class={`
          grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6
          *:flex *:flex-col *:items-center *:justify-center *:gap-2 *:rounded-lg *:border *:border-slate-200 *:text-center *:aspect-square *:transition *:hover:border-teal-500 *:cursor-pointer *:relative`}>

          {items.map((icon) => (
            <IconCard {...icon} />
          ))}

        </div>
      </section>
    ))}

    <p data-icon-empty class="hidden py-10 text-center text-slate-500">
      No icons found with your filters.
    </p>
  </div>
</main>

<script>
  import { initDropdown } from '../scripts/dropdown'
  import { initIconGrid } from '../scripts/iconGrid'

  document.querySelectorAll('[data-icon-grid]').forEach((root) => {
    if (!(root instanceof HTMLElement)) return

    initIconGrid(root)

    const buttons = root.querySelectorAll('[data-outside]')
    const activeClass = 'dropdown-visible'

    buttons.forEach((button) => {
      if (button instanceof HTMLElement) {
        initDropdown(button, activeClass)
      }
    })
  })
</script>
