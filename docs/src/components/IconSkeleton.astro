---
interface Props {
  customClass?: string;
  randomSelector?: string;
}

const { customClass, randomSelector } = Astro.props;

const gridPath = Array.from({ length: 24 }, (_, i) => {
  const pos = (i + 1) * 10;
  return `M0 ${pos}H240 M${pos} 0V240`;
}).join(' ');
---

<svg-skeleton class={`svg-skeleton-wrapper pointer-events-none w-full aspect-square rounded relative ${customClass}`} data-random-selector={randomSelector}>
  <div class="source-slot w-full h-full stroke-1 absolute inset-0 text-slate-500/20 *:w-full *:h-full" aria-hidden="true">
    <slot />
  </div>
  <div class="render-zone w-full h-full relative"></div>
  <svg class="svg-skeleton-bg w-full h-full stroke-1 absolute inset-0 text-slate-500/10" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1">
    <path d={gridPath}/>
  </svg>
</svg-skeleton>

<script>
  import '../scripts/iconSkeleton.js'
</script>
