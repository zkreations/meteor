---
import * as MeteorIcons from '@meteor-icons/astro'
import { toPascalCase } from '../utils/stringCase'

type Props = {
  name: string
  title?: string
}

const { name, title = name } = Astro.props as Props

const componentName = toPascalCase(name)
const IconComponent = MeteorIcons[componentName as keyof typeof MeteorIcons]
---

<section class="border-t border-slate-100 pt-4 mt-10">
  <h2 class="font-semibold text-slate-900 text-xl md:text-2xl mb-6">Icon in action</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <div class="rounded-lg border border-slate-200 transition hover:border-brand-active relative md:p-8 p-5 flex flex-col gap-4">
      <div class="flex gap-2">
        <button class="flex items-center gap-2 bg-slate-900 hover:bg-black text-white text-sm font-medium px-4 py-2.5 rounded-lg">
          <IconComponent />
          New {name}
        </button>
      </div>
      <button class="flex items-center justify-center gap-2 border border-slate-200 text-slate-700 text-sm font-medium px-4 py-2.5 rounded-lg">
        <IconComponent />
        Copy {name}
      </button>
    </div>

    <div class="rounded-lg border border-slate-200 transition hover:border-brand-active relative md:p-8 p-5 flex flex-col gap-4">
      <div class="flex items-center gap-1 border-b border-slate-200">
        <button class="flex items-center gap-1.5 px-3 py-2.5 text-sm text-slate-400">
          <MeteorIcons.Home class="w-4 h-4" />
          Home
        </button>
        <button class="flex items-center gap-1.5 px-3 py-2.5 text-sm text-slate-900 font-medium border-b-2 border-slate-900 -mb-px">
          <IconComponent class="w-4 h-4" />
          {name}
        </button>
        <button class="flex items-center gap-1.5 px-3 py-2.5 text-sm text-slate-400">
          <MeteorIcons.ShoppingBag class="w-4 h-4" />
          Pricing
        </button>
      </div>
      <div class="pt-4 space-y-2">
        <div class="h-2 bg-slate-100 rounded-full w-full"></div>
        <div class="h-2 bg-slate-100 rounded-full w-2/3"></div>
      </div>
    </div>

    <div class="rounded-lg border border-slate-200 transition hover:border-brand-active relative md:p-8 p-5 flex flex-col gap-4">
      <div class="space-y-1">
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg">
          <MeteorIcons.File class="w-6 h-6 text-slate-400" />
          <span class="text-sm text-slate-500 flex-1">readme.md</span>
        </div>
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-slate-50">
          <IconComponent class="w-6 h-6 text-slate-900" />
          <span class="text-sm text-slate-900 font-medium flex-1">{name}.tsx</span>
          <span class="text-xs text-slate-400">2 KB</span>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-slate-200 transition hover:border-brand-active relative md:p-8 p-5 flex flex-col gap-4">
      <div class="flex items-center gap-2 border border-slate-200 rounded-lg px-3 py-2.5 mb-3">
        <MeteorIcons.Search class="w-5 h-5 text-slate-400" />
        <span class="text-sm text-slate-400">Search...</span>
      </div>
      <div class="flex items-center gap-3 px-3 py-2 rounded-lg border border-slate-200">
        <IconComponent class="w-5 h-5 text-slate-900" />
        <span class="text-sm text-slate-900 font-medium">{name}</span>
        <span class="text-xs text-slate-400 ml-auto">UI</span>
      </div>
    </div>

    <div class="rounded-lg border border-slate-200 transition hover:border-brand-active relative md:p-8 p-5 flex flex-col gap-4">
      <div class="w-14 h-14 rounded-lg bg-slate-900 flex items-center justify-center shrink-0">
        <IconComponent class="w-8 h-8  text-white" />
      </div>
      <div>
        <p class="text-sm text-slate-900 font-medium mb-1">{title} is here!</p>
        <p class="text-sm text-slate-400">It's a great day to use the {name} icon in your project. Don't forget to customize it to fit your design!</p>
      </div>
    </div>
  </div>
</section>
