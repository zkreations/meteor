---
import { Copy } from '@meteor-icons/astro'

interface Props {
  defaultFw?: 'astro' | 'react' | 'vue' | 'solid' | 'svelte';
}

const { defaultFw = 'react' } = Astro.props;
const frameworks = ['Astro', 'React', 'Vue', 'Solid', 'Svelte'] as const;
---

<div data-framework-tabs-container class="bg-slate-100 rounded-lg sm:px-5 sm:pt-5 px-4 pt-4">
  <div class="flex items-center gap-3 font-medium text-slate-500 border-b border-slate-200 mb-4">
    <div class="flex items-center gap-3 scrollbar overflow-x-auto overflow-y-hidden whitespace-nowrap">
      {frameworks.map((framework) => (
        <button
          type="button"
          data-impl-toggle={framework.toLowerCase()}
          aria-selected={framework.toLowerCase() === defaultFw ? "true" : "false"}
          class="pb-3 cursor-pointer transition-colors duration-300 aria-selected:text-slate-900 border-b-2 border-transparent aria-selected:border-brand-active"
        >
          {framework}
        </button>
      ))}
    </div>

    <button
      type="button"
      data-copy-impl
      class="pb-3 transition-colors duration-300 shrink-0 text-slate-400 hover:text-slate-700 cursor-pointer ml-auto"
      aria-label="Copy code"
    >
      <Copy size={16} />
    </button>
  </div>

  <div class="flex items-center scrollbar overflow-x-auto overflow-y-hidden sm:pb-5 pb-4">
    <pre data-impl-display class="flex-1 font-mono text-slate-600"></pre>
  </div>
</div>
