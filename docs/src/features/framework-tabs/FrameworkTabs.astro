---
import { Copy } from '@meteor-icons/astro'
import { snippet, type FwKey } from './FrameworkTabs'

interface Props {
  defaultFw?: FwKey
  iconName?: string
  frameworks?: string[]
}

const { defaultFw = 'react', iconName, frameworks = ['Astro', 'React', 'Preact', 'Vue', 'Solid', 'Svelte', 'Hamlet'] } = Astro.props;
---

<div data-framework-tabs-container class="bg-slate-100 rounded-lg sm:px-5 sm:pt-5 px-4 pt-4">
  <div class="flex items-center gap-3 font-medium border-b border-slate-200 mb-4">
    <div
      role="tablist"
      aria-label="Frameworks"
      class="flex items-center gap-3 scrollbar overflow-x-auto overflow-y-hidden whitespace-nowrap"
    >
      {frameworks.map((framework) => (
        <button
          type="button"
          role="tab"
          data-impl-toggle={framework.toLowerCase()}
          aria-selected={framework.toLowerCase() === defaultFw ? "true" : "false"}
          class="pb-3 cursor-pointer transition-colors duration-300 aria-selected:text-slate-900 border-b-2 border-transparent aria-selected:border-brand-active"
        >
          {framework}
        </button>
      ))}
    </div>

    <button
      type="button"
      data-copy-impl
      class="pb-3 transition-colors duration-300 shrink-0 hover:text-slate-900 cursor-pointer ml-auto"
      aria-label="Copy code"
    >
      <Copy minimal class="w-5 h-5"/>
    </button>
  </div>

  <div class="flex items-center scrollbar overflow-x-auto overflow-y-hidden sm:pb-5 pb-4">
    {iconName ? (
      frameworks.map((framework) => {
        const fw = framework.toLowerCase() as FwKey
        return (
          <pre
            role="tabpanel"
            data-impl-content
            data-impl-fw={fw}
            class={`flex-1 font-mono ${fw === defaultFw ? '' : 'hidden'}`}
          >{snippet(iconName, fw)}</pre>
        )
      })
    ) : (
      <pre data-impl-display class="flex-1 font-mono"></pre>
    )}
  </div>
</div>
