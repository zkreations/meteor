---
import { Download, Image, Copy, Sparkles } from '@meteor-icons/astro'

interface Props {
  variant?: 'compact' | 'full'
  size?: number
}

const { variant = 'full' } = Astro.props
---

{variant === 'compact' ? (
  <div class="icon-actions">
    <button type="button" data-action-copy-minimal class="btn icon-action square" title="Copy Minimal SVG" tabindex="-1">
      <Sparkles minimal class="w-4 h-4" />
    </button>
    <button type="button" data-action-copy-svg class="btn icon-action square" title="Copy Full SVG" tabindex="-1">
      <Copy minimal class="w-4 h-4" />
    </button>
    <button type="button" data-action-download-png class="btn icon-action square" title="Download PNG" tabindex="-1">
      <Image minimal class="w-4 h-4" />
    </button>
    <button type="button" data-action-download-svg class="btn icon-action square" title="Download SVG" tabindex="-1">
      <Download minimal class="w-4 h-4" />
    </button>
  </div>
) : (
  <div class="flex items-center gap-2 relative">
    <button type="button" data-action-copy-minimal class="btn icon-action text-hidden">
      <Sparkles minimal class="w-5 h-5" /> Copy Minimal SVG
    </button>
    <button type="button" data-action-copy-svg class="btn icon-action text-hidden">
      <Copy minimal class="w-5 h-5" /> Copy Full SVG
    </button>
    <button type="button" data-action-download-png class="btn icon-action text-hidden">
      <Image minimal class="w-5 h-5" /> PNG
    </button>
    <button type="button" data-action-download-svg class="btn icon-action text-hidden">
      <Download minimal class="w-5 h-5" /> SVG
    </button>
  </div>
)}
