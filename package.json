{
  "name": "meteor-icons",
  "version": "3.7.1",
  "description": "Handcrafted line by line, for as little code as possible",
  "type": "module",
  "scripts": {
    "prebuild": "node ./build/generate-svg.js",
    "build": "run-p build:sprite build:includable",
    "build:sprite": "node ./build/generate-sprite.js",
    "build:includable": "node ./build/generate-includable.js"
  },
  "files": [
    "icons",
    "exports"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zkreations/icons.git"
  },
  "keywords": [],
  "author": "@danieIabel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zkreations/icons/issues"
  },
  "homepage": "https://github.com/zkreations/icons#readme",
  "devDependencies": {
    "cheerio": "^1.1.2",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "npm-run-all": "^4.1.5",
    "svg-sprite": "^2.0.4",
    "svgo": "^4.0.0"
  }
}
