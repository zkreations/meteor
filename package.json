{
  "type": "module",
  "version": "4.0.2",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "author": "@danieIabel",
  "license": "MIT",
  "homepage": "https://github.com/zkreations/meteor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zkreations/meteor.git"
  },
  "bugs": {
    "url": "https://github.com/zkreations/meteor/issues"
  },
  "keywords": [],
  "scripts": {
    "prebuild": "run-s prepare:*",
    "prepare:svg": "node ./build/generate-svg.js",
    "prepare:core": "node ./build/generate-core.js",
    "build": "run-p build:*",
    "build:react": "node ./build/generate-react.js",
    "build:preact": "node ./build/generate-preact.js",
    "build:vue": "node ./build/generate-vue.js",
    "build:solid": "node ./build/generate-solid.js",
    "build:svelte": "node ./build/generate-svelte.js",
    "build:astro": "node ./build/generate-astro.js",
    "build:hamlet": "node ./build/generate-hamlet.js",
    "build:readme": "node ./build/generate-readme.js",
    "build:packages": "node ./build/generate-packages.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run test/core --environment jsdom",
    "test:react": "vitest run test/react --environment jsdom",
    "test:preact": "vitest run test/preact --environment jsdom",
    "test:vue": "vitest run test/vue --environment jsdom",
    "test:solid": "vitest run test/solid --environment jsdom",
    "test:svelte": "vitest run test/svelte --environment jsdom",
    "test:astro": "vitest run test/astro --environment jsdom",
    "test:hamlet": "vitest run test/hamlet",
    "docs:dev": "pnpm --filter @meteor-icons/docs dev",
    "docs:build": "pnpm --filter @meteor-icons/docs build",
    "docs:preview": "pnpm --filter @meteor-icons/docs preview"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@solidjs/testing-library": "^0.8.10",
    "@sveltejs/vite-plugin-svelte": "^7.1.3",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/vue": "^8.1.0",
    "astro": "^7.0.6",
    "cheerio": "^1.2.0",
    "eslint": "^10.6.0",
    "hamlet-builder": "^1.5.9",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "preact": "^10.29.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "solid-js": "^1.9.14",
    "svelte": "^5.56.4",
    "svg-sprite": "^2.0.4",
    "svgo": "^4.0.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10",
    "vue": "^3.5.39"
  }
}
