{
  "name": "@meteor-icons/react",
  "version": "4.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./icons/*": {
      "types": "./src/icons/*.d.ts",
      "import": "./src/icons/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "src"
  ],
  "scripts": {
    "prepack": "npm --prefix ../.. run build"
  },
  "peerDependencies": {
    "react": ">=17"
  }
}
