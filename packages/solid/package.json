{
  "name": "@meteor-icons/solid",
  "version": "4.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.jsx",
  "module": "src/index.jsx",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.jsx"
    },
    "./icons/*": {
      "types": "./src/icons/*.d.ts",
      "import": "./src/icons/*.jsx"
    }
  },
  "sideEffects": false,
  "files": [
    "src"
  ],
  "scripts": {
    "prepack": "npm --prefix ../.. run build"
  },
  "peerDependencies": {
    "solid-js": ">=1.8"
  }
}
